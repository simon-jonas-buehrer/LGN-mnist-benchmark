# Shared A/B base config -- sourced by sweep.sh and backfill.sh.
# One variable changes per arm; winners compound into this BASE, losers get deleted.
# Compounded winners: wave-2 (deep unshared K=6, 8-bit therm, aug) + 2026-07-05 hash-gate
# day: cd-cf lever (in code), POOLING PYRAMID (equal val at 2.6x less compute, half the
# gap), MARGIN 2 (51.4 @ r8 vs 49.4 ctrl), RS-TEMP 0 (+1.7 @ r14 and faster rounds --
# uphill acceptance hurt under margin 2), NUM-BITS 5 (+1.1 @ r14, 40% smaller input),
# WITHIN-RUN EXPLORE ANNEAL 1:0.3:30 (+1-2, confirmed both seeds; scale the schedule to
# the arm's --rounds), EDGE INPUT FEATURES + TTA (+6.7 @ r4 parity -- see --in-feats).
BASE="--channels 80,40,20,20,10,10 --spatial 32,32,16,16,8,8 --num-bits 5 --fan-in 6 \
--init-deg 0,0,0 --in-feats edge --tta 1 --margin 2 --rs-temp 0 --explore 1:0.3:30 --aug full --aug-crop 4 \
--aug-jitter 0.3 --val-every 1 --pass-rows 2048 --rounds 14 --seed 0"
